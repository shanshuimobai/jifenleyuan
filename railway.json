{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd backend && npm install"
  },
  "deploy": {
    "startCommand": "cd backend && node index.js",
    "healthcheckPath": "/api/leaderboard/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
